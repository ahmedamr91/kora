{
  "name": "madraj-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @madraj/web",
    "dev:web": "npm run dev -w @madraj/web",
